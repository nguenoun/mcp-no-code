{
  "name": "mcpbuilder",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "db:generate": "turbo db:generate",
    "db:migrate": "cd packages/db && npx prisma migrate dev",
    "db:studio": "cd packages/db && npx prisma studio",
    "db:push": "cd packages/db && npx prisma db push",
    "cf:setup": "ts-node --project scripts/tsconfig.json scripts/cloudflare-setup.ts",
    "cf:cleanup": "ts-node --project scripts/tsconfig.json scripts/cloudflare-cleanup.ts",
    "cf:sync": "ts-node --project scripts/tsconfig.json scripts/cloudflare-sync.ts",
    "cf:test-worker": "ts-node --project scripts/tsconfig.json scripts/cloudflare-test-worker.ts"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "prettier": "^3.2.5",
    "turbo": "^2.1.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@10.5.0"
}
