// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

enum ServerStatus {
  RUNNING
  STOPPED
  ERROR
}

enum CredentialType {
  API_KEY
  BEARER
  BASIC_AUTH
}

enum CallStatus {
  SUCCESS
  ERROR
}

enum RuntimeMode {
  LOCAL
  CLOUDFLARE
}

enum AuthMode {
  API_KEY
  OAUTH
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String?
  passwordHash String?
  googleId     String?     @unique
  plan         Plan        @default(FREE)
  hasCompletedOnboarding Boolean @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  workspaces   Workspace[]
  oauthCodes   OAuthCode[]
  oauthTokens  OAuthToken[]

  @@map("users")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  userId    String
  createdAt DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  mcpServers  McpServer[]
  credentials Credential[]

  @@index([userId])
  @@map("workspaces")
}

model McpServer {
  id           String       @id @default(cuid())
  workspaceId  String
  name         String
  description  String?
  status       ServerStatus @default(STOPPED)
  runtimeMode  RuntimeMode  @default(LOCAL)
  authMode     AuthMode     @default(API_KEY)
  endpointUrl  String?
  apiKey       String       @unique @default(cuid())
  credentialId String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  credential   Credential?  @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  tools        McpTool[]
  callLogs     CallLog[]
  oauthApps    OAuthApp[]
  oauthTokens  OAuthToken[]

  @@index([workspaceId])
  @@map("mcp_servers")
}

model McpTool {
  id               String    @id @default(cuid())
  mcpServerId      String
  name             String
  description      String?
  httpMethod       String
  httpUrl          String
  parametersSchema Json      @default("{}")
  headersConfig    Json      @default("{}")
  isEnabled        Boolean   @default(true)
  createdAt        DateTime  @default(now())

  mcpServer McpServer @relation(fields: [mcpServerId], references: [id], onDelete: Cascade)

  @@index([mcpServerId])
  @@map("mcp_tools")
}

model Credential {
  id             String         @id @default(cuid())
  workspaceId    String
  name           String
  type           CredentialType
  encryptedValue String
  createdAt      DateTime       @default(now())

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mcpServers  McpServer[]

  @@index([workspaceId])
  @@map("credentials")
}

// ─── OAuth Authorization Server ──────────────────────────────────────────────

// Applications tierces enregistrées (ex : Dust, Zapier) — clients confidentiels
model OAuthApp {
  id               String    @id @default(cuid())
  mcpServerId      String
  name             String
  clientId         String    @unique
  clientSecretHash String
  redirectUris     String[]
  createdAt        DateTime  @default(now())

  mcpServer McpServer   @relation(fields: [mcpServerId], references: [id], onDelete: Cascade)
  codes     OAuthCode[]
  tokens    OAuthToken[]

  @@index([mcpServerId])
  @@map("oauth_apps")
}

// Authorization codes — usage unique, TTL 5 minutes
model OAuthCode {
  id            String    @id @default(cuid())
  code          String    @unique
  userId        String
  clientId      String
  mcpServerId   String
  redirectUri   String
  scopes        String[]
  codeChallenge String
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime  @default(now())

  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client OAuthApp  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([userId])
  @@map("oauth_codes")
}

// Tokens actifs — access (JWT signé) + refresh (opaque)
model OAuthToken {
  id           String    @id @default(cuid())
  jti          String    @unique          // JWT ID pour révocation côté Worker
  accessToken  String    @unique
  refreshToken String?   @unique
  userId       String
  clientId     String
  mcpServerId  String
  scopes       String[]
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    OAuthApp  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  mcpServer McpServer @relation(fields: [mcpServerId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([mcpServerId])
  @@index([jti])
  @@map("oauth_tokens")
}

model CallLog {
  id           String     @id @default(cuid())
  mcpServerId  String
  toolName     String
  status       CallStatus
  latencyMs    Int?
  errorMessage String?
  createdAt    DateTime   @default(now())

  mcpServer McpServer @relation(fields: [mcpServerId], references: [id], onDelete: Cascade)

  @@index([mcpServerId])
  @@index([createdAt])
  @@map("call_logs")
}
